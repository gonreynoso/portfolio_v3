---
import { dict } from "../i18n";

const CASE_LINKS: Record<string, { url: string; image?: string }> = {
  "Refugio Ilón": { url: "/casos/refugioilon-bot", image: "/refugioilonweb.webp" },
  "Estudio Froment & Asociados": { url: "/estudiofroment", image: "/estudiofroment.webp" },
  "Intima Online": { url: "/casos/intima-online" },
  "Medicina Diagnóstica - Centro Médico": { url: "/casos/medicina-diagnostica" },
  "La Carlota del Monte - Tierra de Caballos": { url: "/casos/la-carlota" },
  "Laboratorio Spotorno": { url: "/casos/laboratorio-spotorno" },
  "Legally On The Move - Asesoría Legal para Migrantes": { url: "/casos/legally-on-the-move" },
};
---

<div class="w-full mx-auto container xl:max-w-6xl lg:max-w-5xl px-6 mt-12">
  <div class="mb-4">
    <h2 class="text-3xl font-bold mb-2 text-gray-100">
      <span data-lang="es">{dict.es.experience.title}</span>
      <span data-lang="en">{dict.en.experience.title}</span>
    </h2>
  </div>

  <div class="text-gray-200 dark:text-gray-100 mb-8">
  <!-- Kensiweb umbrella -->
  <section class="relative pl-10 ml-4 border-l-2 border-[#54da7a]/60 pb-10">
    <span class="absolute -left-[9px] top-1 block w-4 h-4 rounded-full bg-[#54da7a]"></span>

    <header class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <h3 class="text-xl font-semibold">
        <span data-lang="es">{dict.es.experience.kensiweb.role}</span>
        <span data-lang="en">{dict.en.experience.kensiweb.role}</span>
        <span class="text-gray-400"> · </span>
        <a href="https://kensiweb.com" target="_blank" rel="noopener noreferrer" class="text-[#54da7a] hover:underline">
          {dict.es.experience.kensiweb.company}
        </a>
      </h3>
      <span class="text-sm text-gray-400">
        <span data-lang="es">
          {dict.es.experience.kensiweb.period} · {dict.es.experience.kensiweb.location}
        </span>
        <span data-lang="en">
          {dict.en.experience.kensiweb.period} · {dict.en.experience.kensiweb.location}
        </span>
      </span>
    </header>

    <p class="mt-2 text-sm text-gray-300 max-w-2xl">
      <span data-lang="es">{dict.es.experience.kensiweb.summary}</span>
      <span data-lang="en">{dict.en.experience.kensiweb.summary}</span>
    </p>

    <div class="mt-5">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">
        <span data-lang="es">{dict.es.experience.kensiweb.clientsLabel}</span>
        <span data-lang="en">{dict.en.experience.kensiweb.clientsLabel}</span>
      </h4>

      <ul class="flex flex-col gap-5">
        {
          dict.es.experience.kensiweb.clients.map((clientEs, i) => {
            const clientEn = dict.en.experience.kensiweb.clients[i];
            return (
              <li class="rounded-lg border border-gray-800 bg-gray-900/40 p-4">
                <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                  <span class="text-sm text-gray-400 uppercase tracking-wider">
                    <span data-lang="es">{dict.es.experience.clientLabel}</span>
                    <span data-lang="en">{dict.en.experience.clientLabel}</span>
                  </span>
                  {
                    CASE_LINKS[clientEs.name]
                      ? <a href={CASE_LINKS[clientEs.name].url} class="font-semibold text-gray-100 hover:text-[#54da7a] transition-colors">{clientEs.name}</a>
                      : <span class="font-semibold text-gray-100">{clientEs.name}</span>
                  }
                  <span class="text-sm text-gray-500">
                    <span data-lang="es">{clientEs.period} · {clientEs.location}</span>
                    <span data-lang="en">{clientEn.period} · {clientEn.location}</span>
                  </span>
                </div>
                <div class="mt-1 text-sm text-gray-300">
                  <span class="text-gray-500">
                    <span data-lang="es">{dict.es.experience.projectLabel} </span>
                    <span data-lang="en">{dict.en.experience.projectLabel} </span>
                  </span>
                  <span data-lang="es">{clientEs.project}</span>
                  <span data-lang="en">{clientEn.project}</span>
                </div>
                <ul class="mt-2 list-disc list-inside text-sm text-gray-300 space-y-1 marker:text-[#54da7a]">
                  {clientEs.bullets.map((b, j) => (
                    <li>
                      <span data-lang="es">{b}</span>
                      <span data-lang="en">{clientEn.bullets[j]}</span>
                    </li>
                  ))}
                </ul>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <!-- Medicina Diagnóstica -->
  <section class="relative pl-10 ml-4 border-l-2 border-gray-700">
    <span class="absolute -left-[9px] top-1 block w-4 h-4 rounded-full bg-gray-500"></span>

    <header class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <h3 class="text-xl font-semibold">
        <span data-lang="es">{dict.es.experience.medicina.role}</span>
        <span data-lang="en">{dict.en.experience.medicina.role}</span>
        <span class="text-gray-400"> · </span>
        <span class="text-gray-200">{dict.es.experience.medicina.company}</span>
      </h3>
      <span class="text-sm text-gray-400">
        <span data-lang="es">
          {dict.es.experience.medicina.period} · {dict.es.experience.medicina.location}
        </span>
        <span data-lang="en">
          {dict.en.experience.medicina.period} · {dict.en.experience.medicina.location}
        </span>
      </span>
    </header>

    <ul class="mt-2 list-disc list-inside text-sm text-gray-300 space-y-1 marker:text-gray-500">
      {
        dict.es.experience.medicina.bullets.map((b, i) => (
          <li>
            <span data-lang="es">{b}</span>
            <span data-lang="en">{dict.en.experience.medicina.bullets[i]}</span>
          </li>
        ))
      }
    </ul>
  </section>
</div>

  </div>
<div class="divider my-0"></div>
