---
import { dict } from "../i18n";

type Turn = { from: "user" | "bot"; text: string };

const mockups: Record<"es" | "en", { header: string; status: string; timestamp: string; chat: Turn[] }> = {
  es: {
    header: dict.es.waMockup.header,
    status: dict.es.waMockup.headerStatus,
    timestamp: dict.es.waMockup.timestamp,
    chat: dict.es.waMockup.chat as Turn[],
  },
  en: {
    header: dict.en.waMockup.header,
    status: dict.en.waMockup.headerStatus,
    timestamp: dict.en.waMockup.timestamp,
    chat: dict.en.waMockup.chat as Turn[],
  },
};
---

<div class="relative overflow-hidden bg-[#0b141a] w-full">
  <!-- Header -->
  <div class="flex items-center gap-3 bg-[#202c33] px-4 py-3">
    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#128C7E] to-[#075E54] flex items-center justify-center text-white font-bold text-sm">
      RI
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-white font-medium text-sm truncate">
        <span data-lang="es">{mockups.es.header}</span>
        <span data-lang="en">{mockups.en.header}</span>
      </div>
      <div class="text-[#8696a0] text-xs truncate">
        <span data-lang="es">{mockups.es.status}</span>
        <span data-lang="en">{mockups.en.status}</span>
      </div>
    </div>
    <svg class="w-5 h-5 text-[#8696a0]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
  </div>

  <!-- Chat body with "doodle" pattern -->
  <div class="relative px-4 py-5 min-h-[320px]" style="background-color:#0b141a; background-image: radial-gradient(circle at 20% 20%, rgba(255,255,255,.02) 0, transparent 40%), radial-gradient(circle at 80% 60%, rgba(255,255,255,.02) 0, transparent 40%);">
    {(["es", "en"] as const).map((lang) => (
      <div data-lang={lang} class="flex flex-col gap-2">
        {mockups[lang].chat.map((turn) => (
          <div class:list={["flex", turn.from === "user" ? "justify-end" : "justify-start"]}>
            <div
              class:list={[
                "max-w-[78%] rounded-lg px-3 py-2 text-sm leading-snug shadow",
                turn.from === "user"
                  ? "bg-[#005c4b] text-white rounded-tr-none"
                  : "bg-[#202c33] text-[#e9edef] rounded-tl-none",
              ]}
            >
              <p class="whitespace-pre-line">{turn.text}</p>
              <div class="mt-1 text-right text-[10px] text-[#8696a0]">
                {mockups[lang].timestamp}
                {turn.from === "user" && (
                  <svg class="inline-block ml-1 w-3 h-3 text-[#53bdeb]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                    <polyline points="24 6 13 17" style="opacity:.7"/>
                  </svg>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</div>
