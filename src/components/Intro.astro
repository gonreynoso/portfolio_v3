---
import CopyButton from "./CopyButton.astro";
import { dict } from "../i18n";
import { primaryCta, secondaryCta } from "../lib/buttons";

const EMAIL = "gonzalo.reynoso9@gmail.com";
const LINKEDIN = "https://linkedin.com/in/gonreynoso";
const GITHUB = "https://github.com/gonreynoso";
const KENSIWEB = "https://kensiweb.com";
const RESUME_ES = "/Resume_Gonzalo_Reynoso_ES.pdf";
const RESUME_EN = "/Resume_Gonzalo_Reynoso_EN.pdf";
---

<section class="h-screen flex flex-col items-center justify-center text-center px-4 pt-20">
  
  <!-- Top: Image -->
  <div class="relative mb-12">
    <img
      class="w-64 h-64 md:w-80 md:h-80 rounded-full object-cover shadow-xl ring-4 ring-[#54da7a]/30"
      src="/picture-profile.webp"
      alt="Gonzalo Reynoso"
    />
  </div>

  <!-- Name & Role -->
  <div class="mb-8">
    <p class="text-xl text-[#54da7a] font-semibold mb-2">
      <span data-lang="es">{dict.es.hero.greeting}</span>
      <span data-lang="en">{dict.en.hero.greeting}</span>
    </p>
    <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold text-gray-100 leading-tight">
      <span data-lang="es">{dict.es.hero.name}</span>
      <span data-lang="en">{dict.en.hero.name}</span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-400 mt-4">
      Freelance Developer · 
      <a href={KENSIWEB} target="_blank" rel="noopener noreferrer" class="text-[#54da7a] hover:underline">
        Kensiweb
      </a>
    </p>
  </div>

  <!-- Tagline -->
  <p class="text-2xl md:text-3xl text-gray-200 mb-6 max-w-3xl leading-relaxed">
    <span data-lang="es">{dict.es.hero.tagline}</span>
    <span data-lang="en">{dict.en.hero.tagline}</span>
  </p>

  <!-- Bio -->
  <p class="text-lg md:text-xl text-gray-400 mb-10 max-w-2xl leading-relaxed">
    <span data-lang="es">{dict.es.hero.bio}</span>
    <span data-lang="en">{dict.en.hero.bio}</span>
  </p>

  <!-- CTAs -->
  <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
    <button type="button" data-open-contact class={`${primaryCta} text-lg px-6 py-3`}>
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <span data-lang="es">{dict.es.hero.ctaContact}</span>
      <span data-lang="en">{dict.en.hero.ctaContact}</span>
    </button>

    <a href={RESUME_ES} target="_blank" rel="noopener noreferrer" class={`${secondaryCta} text-lg px-5 py-3`} data-lang="es">
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zm7 1.5L18.5 9H13V3.5zM8 11h8v2H8v-2zm0 4h8v2H8v-2z"></path>
      </svg>
      CV
    </a>
  </div>

  <!-- Social links row -->
  <div class="flex items-center gap-8 text-lg text-gray-400">
    <a href={LINKEDIN} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-[#54da7a] transition-colors">
      <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
        <rect x="2" y="9" width="4" height="12"></rect>
        <circle cx="4" cy="4" r="2"></circle>
      </svg>
      <span>LinkedIn</span>
    </a>

    <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-[#54da7a] transition-colors">
      <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
      </svg>
      <span>GitHub</span>
    </a>

    <div class="flex items-center gap-2 border-l border-gray-600 pl-8">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
        <path d="M2.94 6.34A2 2 0 012 5V4a2 2 0 012-2h12a2 2 0 012 2v1a2 2 0 01-.94 1.34L10 10 2.94 6.34zM2 8.12V15a2 2 0 002 2h12a2 2 0 002-2V8.12l-7.06 4.14a1 1 0 01-.88 0L2 8.12z"></path>
      </svg>
      <span class="text-base">{EMAIL}</span>
      <CopyButton text={EMAIL} />
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#servicios" class="mt-16 flex flex-col items-center gap-2 text-gray-500 hover:text-[#54da7a] transition-colors" onclick="event.preventDefault(); document.getElementById('servicios').scrollIntoView({ behavior: 'smooth' });">
    <span class="text-sm uppercase tracking-widest">Scroll</span>
    <svg class="w-8 h-8 animate-bounce" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>