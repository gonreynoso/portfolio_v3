---
import { dict } from "../i18n";

const { text = "" } = Astro.props;
---

<button
  class="copy-button px-4 py-2 bg-gray-800 text-gray-100 hover:bg-gray-700 hover:text-white border border-gray-700 font-medium flex items-center relative transition"
  data-text={text}
>
  <span class="button-text">
    <span data-lang="es">{dict.es.ui.copy}</span>
    <span data-lang="en">{dict.en.ui.copy}</span>
  </span>
  <span
    class="copy-message absolute right-0 top-[-2rem] text-sm bg-black text-white px-2 py-1 rounded invisible opacity-0 transition-opacity duration-300"
  >
    <span data-lang="es">{dict.es.ui.copied}</span>
    <span data-lang="en">{dict.en.ui.copied}</span>
  </span>
</button>

<script is:inline>
  (function setupCopyButtons() {
    document.querySelectorAll(".copy-button").forEach((button) => {
      if (button.__copyBound) return;
      button.__copyBound = true;
      const copyMessage = button.querySelector(".copy-message");
      button.addEventListener("click", async () => {
        const textToCopy = button.getAttribute("data-text") || "";
        try {
          await navigator.clipboard.writeText(textToCopy);
        } catch {
          const ta = document.createElement("textarea");
          ta.value = textToCopy;
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand("copy"); } catch {}
          ta.remove();
        }
        if (copyMessage) {
          copyMessage.classList.remove("invisible", "opacity-0");
          copyMessage.classList.add("opacity-100");
          setTimeout(() => {
            copyMessage.classList.add("invisible", "opacity-0");
            copyMessage.classList.remove("opacity-100");
          }, 1500);
        }
      });
    });
  })();
</script>
