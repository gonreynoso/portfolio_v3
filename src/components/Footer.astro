---
import { dict } from "../i18n";

const today = new Date();
---

<footer class="mb-5 pt-10 text-center text-sm text-gray-400">
  <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
    <span>
      <span data-lang="es">{dict.es.footer.developedBy}</span>
      <span data-lang="en">{dict.en.footer.developedBy}</span>
      &copy; {today.getFullYear()}
    </span>
    <span class="text-gray-600">·</span>
    <span>
      <span data-lang="es">{dict.es.footer.brandNote}</span>
      <span data-lang="en">{dict.en.footer.brandNote}</span>
      <a
        href="https://kensiweb.com"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-1 text-[#54da7a] hover:underline"
      >
        kensiweb.com
      </a>
    </span>
  </div>
</footer>
