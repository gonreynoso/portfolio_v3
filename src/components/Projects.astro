---
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import WhatsAppMockup from "./WhatsAppMockup.astro";
import { dict } from "../i18n";

type Tag = { name: string; class: string };

const TAG: Record<string, Tag> = {
  WA_API: { name: "WhatsApp Cloud API", class: "bg-[#25D366] text-black" },
  CLAUDE: { name: "Claude API", class: "bg-[#d97757] text-white" },
  NODE: { name: "Node.js", class: "bg-[#539e43] text-white" },
  EXPRESS: { name: "Express", class: "bg-[#111827] text-white border border-gray-700" },
  POSTGRES: { name: "PostgreSQL", class: "bg-[#336791] text-white" },
  DO: { name: "DigitalOcean", class: "bg-[#0080ff] text-white" },
  SASS: { name: "SASS", class: "bg-[#cd6799] text-white" },
  JS: { name: "JavaScript", class: "bg-[#f7df1e] text-black" },
  BOOTSTRAP: { name: "Bootstrap", class: "bg-[#7952b3] text-white" },
  HTML: { name: "HTML", class: "bg-[#e34f26] text-white" },
  WORDPRESS: { name: "WordPress", class: "bg-[#21759B] text-white" },
  PHP: { name: "PHP", class: "bg-[#777BB4] text-white" },
  SQL: { name: "SQL", class: "bg-[#00758F] text-white" },
  ANGULAR: { name: "Angular", class: "bg-[#dd0031] text-white" },
  TYPESCRIPT: { name: "TypeScript", class: "bg-[#3178c6] text-white" },
  ASTR: { name: "Astro", class: "bg-[#bc52ee] text-white" },
  TAILWIND: { name: "Tailwind CSS", class: "bg-[#38bdf8] text-black" },
  GSAP: { name: "GSAP", class: "bg-[#88ce02] text-black" },
  NEXTJS: { name: "Next.js", class: "bg-black text-white border border-gray-700" },
  LARAVEL: { name: "Laravel", class: "bg-[#ff2d20] text-white" },
  LIVEWIRE: { name: "Livewire", class: "bg-[#4e56a6] text-white" },
  MYSQL: { name: "MySQL", class: "bg-[#4479a1] text-white" },
  VERCEL: { name: "Vercel", class: "bg-[#111111] text-white border border-gray-700" },
  MERCADOPAGO: { name: "Mercado Pago", class: "bg-[#009ee3] text-white" },
  PYTHON: { name: "Python", class: "bg-[#3776ab] text-white" },
  FASTAPI: { name: "FastAPI", class: "bg-[#009688] text-white" },
};

type ProjectKey = keyof typeof dict.es.projects.items;

type Project = {
  key: ProjectKey;
  image?: string;
  mockup?: "whatsapp";
  link: string | null;
  external: boolean;
  github: string | null;
  tags: Tag[];
};

const PROJECTS: Project[] = [
  {
    key: "ilonBot",
    mockup: "whatsapp",
    link: "/casos/refugioilon-bot",
    external: false,
    github: null,
    tags: [TAG.PYTHON, TAG.FASTAPI, TAG.CLAUDE, TAG.WA_API, TAG.POSTGRES, TAG.DO],
  },
  {
    key: "froment",
    image: "/estudiofroment.webp",
    link: "/estudiofroment",
    external: false,
    github: null,
    tags: [TAG.ASTR, TAG.TAILWIND, TAG.GSAP, TAG.VERCEL],
  },
  {
    key: "ilonBooking",
    image: "/refugioilonweb.webp",
    link: "/casos/refugioilon-booking",
    external: false,
    github: null,
    tags: [TAG.LARAVEL, TAG.LIVEWIRE, TAG.TAILWIND, TAG.MYSQL, TAG.MERCADOPAGO],
  },
  {
    key: "baiardiReservas",
    image: "/baiardireservas.webp",
    link: "/casos/baiardi-reservas",
    external: false,
    github: null,
    tags: [TAG.LARAVEL, TAG.LIVEWIRE, TAG.TAILWIND, TAG.MERCADOPAGO, TAG.DO],
  },

  {
    key: "intimaOnline",
    image: "/intimaonline.webp",
    link: "/casos/intima-online",
    external: false,
    github: null,
    tags: [TAG.ASTR, TAG.TAILWIND, TAG.TYPESCRIPT],
  },
  {
    key: "medicinaDiagnostica",
    image: "/medicinadiagnostica.webp",
    link: "/casos/medicina-diagnostica",
    external: false,
    github: null,
    tags: [TAG.NEXTJS, TAG.TYPESCRIPT, TAG.TAILWIND, TAG.GSAP],
  },
  {
    key: "laCarlota",
    image: "/lacarlota.webp",
    link: "/casos/la-carlota",
    external: false,
    github: null,
    tags: [TAG.ASTR, TAG.TAILWIND],
  },
  {
    key: "laboratorioSpotorno",
    image: "/laboratoriospotorno.webp",
    link: "/casos/laboratorio-spotorno",
    external: false,
    github: null,
    tags: [TAG.HTML, TAG.TAILWIND],
  },
  {
    key: "legallyOnTheMove",
    image: "/legallyonthemove.webp",
    link: "/casos/legally-on-the-move",
    external: false,
    github: null,
    tags: [TAG.HTML, TAG.TAILWIND, TAG.GSAP],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ key, image, mockup, link, external, github, tags }) => {
      const mediaClass =
        "relative flex flex-col items-center gap-8 shadow-xl overflow-clip rounded-xl border border-gray-800 transition duration-500 ease-in-out transform md:hover:-translate-y-1 md:hover:shadow-2xl hover:border-gray-700";

      const media =
        mockup === "whatsapp" ? (
          <WhatsAppMockup />
        ) : image ? (
          <img
            alt="Project image"
            class="object-cover w-full h-56 max-h-56"
            src={image}
          />
        ) : (
          <div class="w-full h-56 bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center">
            <span class="text-gray-500 text-sm">Proximamente</span>
          </div>
        );

      return (
        <article class="flex flex-col space-x-0 space-y-8 md:flex-row md:space-x-8 md:space-y-0">
          <div class="w-full md:w-1/2">
            {link ? (
              <a
                href={link}
                target={external ? "_blank" : undefined}
                rel={external ? "noopener noreferrer" : undefined}
                class="block"
              >
                <div class={mediaClass}>{media}</div>
              </a>
            ) : (
              <div class={mediaClass}>{media}</div>
            )}
          </div>

        <div class="w-full md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-gray-200 dark:text-gray-100">
            <span data-lang="es">{dict.es.projects.items[key].title}</span>
            <span data-lang="en">{dict.en.projects.items[key].title}</span>
          </h3>

          <ul class="flex flex-wrap gap-2 mt-3">
            {tags.map((t) => (
              <li>
                <span class:list={["inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full", t.class]}>
                  {t.name}
                </span>
              </li>
            ))}
          </ul>

          <div class="mt-3 text-gray-200 dark:text-gray-100 text-sm leading-relaxed">
            <span data-lang="es">{dict.es.projects.items[key].description}</span>
            <span data-lang="en">{dict.en.projects.items[key].description}</span>
          </div>

          <footer class="flex items-end justify-start mt-4 gap-x-4">
            {github && (
              <LinkButton href={github}>
                <GitHub class="w-6 h-6" />
                Code
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <Link class="w-4 h-4" />
                <span data-lang="es">{dict.es.projects.items[key].linkLabel}</span>
                <span data-lang="en">{dict.en.projects.items[key].linkLabel}</span>
              </LinkButton>
            )}
            </footer>
          </div>
        </article>
      );
    })
  }
  <div class="divider my-0"></div>
</div>
