---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import { ViewTransitions } from "astro:transitions";
import Analytics from "../components/Analytics/Analytics.astro";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogType,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="lang-es" data-theme="dark">
  <head>
    <script is:inline>
      // Apply saved theme before render
      (() => {
        try {
          const theme = localStorage.getItem("theme");
          if (theme === "light") {
            document.documentElement.classList.remove("dark");
            document.documentElement.setAttribute("data-theme", "light");
          } else {
            document.documentElement.classList.add("dark");
            document.documentElement.setAttribute("data-theme", "dark");
          }
        } catch (_) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <script is:inline>
      // i18n runtime:
      //   - runs synchronously before first paint so the wrong
      //     language never flickers,
      //   - re-applies on every View Transitions swap (the new
      //     static HTML always ships with `class="lang-es"`, so we
      //     override it before the new body paints),
      //   - click delegation on `document` so the LangToggle keeps
      //     working after swaps without needing to rebind.
      (() => {
        const apply = (forceLang) => {
          let lang = forceLang;
          if (!lang) {
            try { lang = localStorage.getItem("lang"); } catch (_) {}
          }
          if (lang !== "es" && lang !== "en") {
            lang =
              typeof navigator !== "undefined" &&
              navigator.language &&
              navigator.language.toLowerCase().startsWith("es")
                ? "es"
                : "en";
          }
          const html = document.documentElement;
          html.classList.remove("lang-es", "lang-en");
          html.classList.add("lang-" + lang);
          html.setAttribute("lang", lang);

          document.querySelectorAll("[data-lang-toggle]").forEach((btn) => {
            btn.dataset.current = lang;
            const esLabel = btn.querySelector('[data-lang-label="es"]');
            const enLabel = btn.querySelector('[data-lang-label="en"]');
            if (esLabel && enLabel) {
              esLabel.classList.toggle("font-bold", lang === "es");
              esLabel.classList.toggle("text-gray-400", lang !== "es");
              enLabel.classList.toggle("font-bold", lang === "en");
              enLabel.classList.toggle("text-gray-400", lang !== "en");
            }
          });
        };

        apply();

        // Click delegation — `document` survives View Transitions, so
        // we only register once and it keeps firing on every page.
        document.addEventListener("click", (e) => {
          const t = e.target instanceof Element ? e.target : null;
          const btn = t && t.closest("[data-lang-toggle]");
          if (!btn) return;
          const next = btn.dataset.current === "es" ? "en" : "es";
          try { localStorage.setItem("lang", next); } catch (_) {}
          apply(next);
        });

        // Re-apply after every View Transitions swap, before the new
        // page is painted, so the static `class="lang-es"` does not
        // flash the wrong language.
        document.addEventListener("astro:after-swap", () => apply());
      })();
    </script>
    <BaseHead
      title={title}
      description={description}
      image={image}
      ogType={ogType}
    />
    {TRANSITION_API && <ViewTransitions />}
  </head>
  <body>
    <div class="bg-base-100 mx-auto">
      <Navbar />
      <div class="md:flex md:justify-center">
        <main class="p-6 pt-10 xl:max-w-[1200px] lg:max-w-[1000px] max-w-[100vw]">
          <slot />
          <Analytics />
        </main>
      </div>
      <Footer />
    </div>
  </body>
</html>
