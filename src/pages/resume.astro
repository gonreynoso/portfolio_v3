---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkExperience from "../components/WorkExperience.astro";
import ContactModal from "../components/ContactModal.astro";
import { dict } from "../i18n";
import { primaryCta } from "../lib/buttons";

const esR = dict.es.resume;
const enR = dict.en.resume;

type SkillGroup = keyof typeof esR.skillsGroups;
const skillGroups = Object.keys(esR.skillsGroups) as SkillGroup[];
---

<BaseLayout title="Gonzalo Reynoso · Resume">
  <div class="mt-28 mb-6 flex flex-wrap items-center justify-between gap-4">
    <h1 class="text-3xl font-bold text-gray-100">
      <span data-lang="es">{esR.profileTitle}</span>
      <span data-lang="en">{enR.profileTitle}</span>
    </h1>
    <a
      href="/Resume_Gonzalo_Reynoso_ES.pdf"
      target="_blank"
      rel="noopener noreferrer"
      data-lang="es"
      class={primaryCta}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      {esR.downloadPdf}
    </a>
    <a
      href="/Resume_Gonzalo_Reynoso_EN.pdf"
      target="_blank"
      rel="noopener noreferrer"
      data-lang="en"
      class={primaryCta}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      {enR.downloadPdf}
    </a>
  </div>

  <p class="mb-10 text-gray-300 leading-relaxed max-w-3xl">
    <span data-lang="es">{esR.profileBody}</span>
    <span data-lang="en">{enR.profileBody}</span>
  </p>

  <WorkExperience />

  <!-- Internship -->
  <div class="mt-16 mb-6">
    <h2 class="text-3xl font-bold text-gray-100">
      <span data-lang="es">{esR.internshipsTitle}</span>
      <span data-lang="en">{enR.internshipsTitle}</span>
    </h2>
  </div>

  <section class="relative pl-6 border-l-2 border-gray-700 text-gray-200 dark:text-gray-100 mb-10">
    <span class="absolute -left-[9px] top-1 block w-4 h-4 rounded-full bg-gray-500"></span>
    <header class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <h3 class="text-xl font-semibold">{esR.internship.role} · {esR.internship.company}</h3>
      <span class="text-sm text-gray-400">
        <span data-lang="es">{esR.internship.period} · {esR.internship.location}</span>
        <span data-lang="en">{enR.internship.period} · {enR.internship.location}</span>
      </span>
    </header>
    <ul class="mt-2 list-disc list-inside text-sm text-gray-300 space-y-1 marker:text-gray-500">
      {
        esR.internship.bullets.map((b, i) => (
          <li>
            <span data-lang="es">{b}</span>
            <span data-lang="en">{enR.internship.bullets[i]}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Education -->
  <div class="mt-16 mb-6">
    <h2 class="text-3xl font-bold text-gray-100">
      <span data-lang="es">{esR.educationTitle}</span>
      <span data-lang="en">{enR.educationTitle}</span>
    </h2>
  </div>

  <div class="grid gap-4 mb-10">
    {
      esR.education.map((item, i) => {
        const en = enR.education[i];
        return (
          <article class="rounded-lg border border-gray-800 bg-gray-900/40 p-4 text-gray-200 dark:text-gray-100">
            <header class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="text-lg font-semibold">
                <span data-lang="es">{item.title}</span>
                <span data-lang="en">{en.title}</span>
              </h3>
              <span class="text-gray-400"> · </span>
              <span class="text-sm text-gray-300">{item.where}</span>
              <span class="text-sm text-gray-500 ml-auto">
                <span data-lang="es">
                  {item.period}{item.location ? ` · ${item.location}` : ""}
                </span>
                <span data-lang="en">
                  {en.period}{en.location ? ` · ${en.location}` : ""}
                </span>
              </span>
            </header>
            <ul class="mt-2 list-disc list-inside text-sm text-gray-300 space-y-1 marker:text-[#54da7a]">
              {
                item.bullets.map((b, j) => (
                  <li>
                    <span data-lang="es">{b}</span>
                    <span data-lang="en">{en.bullets[j]}</span>
                  </li>
                ))
              }
            </ul>
          </article>
        );
      })
    }
  </div>

  <!-- Certifications -->
  <div class="mt-16 mb-6">
    <h2 class="text-3xl font-bold text-gray-100">
      <span data-lang="es">{esR.certificationsTitle}</span>
      <span data-lang="en">{enR.certificationsTitle}</span>
    </h2>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2 text-gray-200">
    {
      esR.certifications.map((c, i) => (
        <li>
          <a href={c.href} target="_blank" rel="noopener noreferrer" class="hover:text-[#54da7a] transition">
            <span data-lang="es">{c.label}</span>
            <span data-lang="en">{enR.certifications[i].label}</span>
            {" "}
            <strong class="font-semibold">{c.issuer}</strong>
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Skills -->
  <div class="mt-16 mb-6">
    <h2 class="text-3xl font-bold text-gray-100">
      <span data-lang="es">{esR.skillsTitle}</span>
      <span data-lang="en">{enR.skillsTitle}</span>
    </h2>
  </div>

  <div class="grid gap-3 mb-16 text-gray-200 dark:text-gray-100">
    {
      skillGroups.map((g) => (
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <span class="text-sm font-semibold text-[#54da7a] min-w-[5.5rem]">
            <span data-lang="es">{esR.skillsGroupLabels[g]}</span>
            <span data-lang="en">{enR.skillsGroupLabels[g]}</span>
          </span>
          <span class="text-sm text-gray-300">{esR.skillsGroups[g].join(" · ")}</span>
        </div>
      ))
    }
  </div>

  <ContactModal />
</BaseLayout>
