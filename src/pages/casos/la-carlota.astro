---
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";
import { dict } from "../../i18n";

const esC = dict.es.cases.laCarlota;
const enC = dict.en.cases.laCarlota;
const key = "la-carlota";
const frontendBadges = ["Astro", "Tailwind CSS"];
const libraryBadges: string[] = [];
const deployBadges: string[] = [];
---

<CaseStudyLayout
  title={esC.title}
  description={esC.summary}
  image="/lacarlota.webp"
  heroImage="/lacarlota.webp"
  cardImage="/lacarlota.webp"
  cardAlt="La Carlota del Monte - Tierra de Caballos"
  accentColor="#b8860b"
  esContent={{ badge: esC.badge, role: esC.role, summary: esC.summary, backToHome: esC.backToHome }}
  enContent={{ badge: enC.badge, role: enC.role, summary: enC.summary, backToHome: enC.backToHome }}
  esSections={esC.sections}
  enSections={enC.sections}
  esSpecs={esC.specs}
  enSpecs={enC.specs}
  specsData={{
    envValue: esC.specs.envValue,
    frontendBadges,
    libraryBadges,
    deployBadges,
    ctaUrl: esC.specs.ctaUrl,
  }}
/>
