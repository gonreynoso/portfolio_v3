---
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";
import { dict } from "../../i18n";

const esC = dict.es.cases.intimaOnline;
const enC = dict.en.cases.intimaOnline;
const key = "intimaonline";
const frontendBadges = ["Astro", "Tailwind CSS", "TypeScript"];
const libraryBadges: string[] = [];
const deployBadges: string[] = [];
---

<CaseStudyLayout
  title={esC.title}
  description={esC.summary}
  image="/intimaonline.webp"
  heroImage="/intimaonline.webp"
  cardImage="/intimaonline.webp"
  cardAlt="Intima Online - Radio Online"
  esContent={{ badge: esC.badge, role: esC.role, summary: esC.summary, backToHome: esC.backToHome }}
  enContent={{ badge: enC.badge, role: enC.role, summary: enC.summary, backToHome: enC.backToHome }}
  esSections={esC.sections}
  enSections={enC.sections}
  esSpecs={esC.specs}
  enSpecs={enC.specs}
  specsData={{
    envValue: esC.specs.envValue,
    frontendBadges,
    libraryBadges,
    deployBadges,
    ctaUrl: esC.specs.ctaUrl,
  }}
/>
