---
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";
import { dict } from "../../i18n";

const esC = dict.es.cases.legallyOnTheMove;
const enC = dict.en.cases.legallyOnTheMove;
const key = "legally-on-the-move";
const frontendBadges = ["Astro", "Tailwind CSS", "TypeScript"];
const libraryBadges = ["GSAP"];
const deployBadges: string[] = [];
---

<CaseStudyLayout
  title={esC.title}
  description={esC.summary}
  image={`/projects/${key}.png`}
  heroImage={`/projects/${key}.png`}
  cardImage={`/${key}.webp`}
  cardAlt="Legally On The Move"
  accentColor="#8b5cf6"
  esContent={{ badge: esC.badge, role: esC.role, summary: esC.summary, backToHome: esC.backToHome }}
  enContent={{ badge: enC.badge, role: enC.role, summary: enC.summary, backToHome: enC.backToHome }}
  esSections={esC.sections}
  enSections={enC.sections}
  esSpecs={esC.specs}
  enSpecs={enC.specs}
  specsData={{
    envValue: esC.specs.envValue,
    frontendBadges,
    libraryBadges,
    deployBadges,
    ctaUrl: esC.specs.ctaUrl,
  }}
/>
