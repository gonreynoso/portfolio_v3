---
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";
import { dict } from "../../i18n";

const esC = dict.es.cases.laboratorioSpotorno;
const enC = dict.en.cases.laboratorioSpotorno;
const key = "laboratorio-spotorno";
const frontendBadges = ["HTML", "Tailwind CSS"];
const libraryBadges: string[] = [];
const deployBadges: string[] = [];
---

<CaseStudyLayout
  title={esC.title}
  description={esC.summary}
  image="/laboratoriospotorno.webp"
  heroImage="/laboratoriospotorno.webp"
  cardImage="/laboratoriospotorno.webp"
  cardAlt="Laboratorio Spotorno"
  accentColor="#2563eb"
  esContent={{ badge: esC.badge, role: esC.role, summary: esC.summary, backToHome: esC.backToHome }}
  enContent={{ badge: enC.badge, role: enC.role, summary: enC.summary, backToHome: enC.backToHome }}
  esSections={esC.sections}
  enSections={enC.sections}
  esSpecs={esC.specs}
  enSpecs={enC.specs}
  specsData={{
    envValue: esC.specs.envValue,
    frontendBadges,
    libraryBadges,
    deployBadges,
    ctaUrl: esC.specs.ctaUrl,
  }}
/>
