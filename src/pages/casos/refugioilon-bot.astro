---
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";
import { dict } from "../../i18n";

const esC = dict.es.cases.refugioilonBot;
const enC = dict.en.cases.refugioilonBot;
const key = "refugioilon-bot";
const frontendBadges = ["WhatsApp Cloud API"];
const libraryBadges = ["Claude API"];
const deployBadges = ["PostgreSQL", "DigitalOcean"];
---

<CaseStudyLayout
  title={esC.title}
  description={esC.summary}
  image="/refugioilonweb.webp"
  heroImage="/refugioilonweb.webp"
  cardImage="/refugioilonweb.webp"
  cardAlt="Refugio Ilón · WhatsApp Bot interface"
  accentColor="#25D366"
  esContent={{ badge: esC.badge, role: esC.role, summary: esC.summary, backToHome: esC.backToHome }}
  enContent={{ badge: enC.badge, role: enC.role, summary: enC.summary, backToHome: enC.backToHome }}
  esSections={esC.sections}
  enSections={enC.sections}
  esSpecs={esC.specs}
  enSpecs={enC.specs}
  specsData={{
    envValue: esC.specs.envValue,
    frontendBadges,
    libraryBadges,
    deployBadges,
  }}
/>
