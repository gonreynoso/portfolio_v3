---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactModal from "../components/ContactModal.astro";
import { dict } from "../i18n";

const title = dict.es.caseFroment.title;
const description = dict.es.caseFroment.summary;
const heroImage = "/estudiofroment.webp";
const cardImage = "/estudiofroment.webp";

const esC = dict.es.caseFroment;
const enC = dict.en.caseFroment;

const frontendBadges = ["SASS (SCSS)", "Bootstrap 5", "JavaScript ES6"];
const libraryBadges = ["Swiper.js", "Lenis"];
const deployBadges = ["Vercel + Git", "NIC.ar DNS"];
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article class="text-gray-200 dark:text-gray-100 mt-20">
    <!-- Hero -->
    <a
      href="/"
      class="inline-flex items-center gap-1 mb-4 text-xs uppercase tracking-widest text-[#c5a059] hover:text-white transition"
    >
      <span data-lang="es">{esC.backToHome}</span>
      <span data-lang="en">{enC.backToHome}</span>
    </a>

    <header
      class="relative overflow-hidden rounded-2xl border border-[#c5a059]/30 mb-10"
      style={`background-image: linear-gradient(rgba(10,10,10,0.86), rgba(10,10,10,0.86)), url('${heroImage}'); background-size: cover; background-position: center;`}
    >
      <div class="px-6 md:px-12 py-14 md:py-16 text-center">
        <h6 class="text-[#c5a059] uppercase tracking-[0.3em] text-xs font-bold">
          <span data-lang="es">{esC.badge}</span>
          <span data-lang="en">{enC.badge}</span>
        </h6>
        <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight">
          {esC.title}
        </h1>
        <p class="mt-4 max-w-2xl mx-auto text-base md:text-lg text-[#d3bc85]">
          <span data-lang="es">{esC.role}</span>
          <span data-lang="en">{enC.role}</span>
        </p>
        <p class="mt-3 max-w-2xl mx-auto text-sm text-gray-300">
          <span data-lang="es">{esC.summary}</span>
          <span data-lang="en">{enC.summary}</span>
        </p>
      </div>
    </header>

    <div class="grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-10">
        <!-- Challenge -->
        <section class="border-b border-gray-800 pb-8">
          <h2 class="case-title text-2xl font-semibold relative pb-3 mb-4">
            <span class="text-[#c5a059] mr-2">{esC.sections.challenge.number}.</span>
            <span data-lang="es">{esC.sections.challenge.title}</span>
            <span data-lang="en">{enC.sections.challenge.title}</span>
          </h2>
          <p class="text-gray-300 leading-relaxed">
            <span data-lang="es">{esC.sections.challenge.body}</span>
            <span data-lang="en">{enC.sections.challenge.body}</span>
          </p>
          <figure class="mt-6">
            <img
              src={cardImage}
              alt="Estudio Froment · Homepage capture"
              class="rounded-lg border border-gray-800 shadow-lg w-full"
            />
            <figcaption class="mt-2 text-center text-xs italic text-gray-500">
              <span data-lang="es">Captura de la home — Kensiweb, 2025.</span>
              <span data-lang="en">Homepage capture — Kensiweb, 2025.</span>
            </figcaption>
          </figure>
        </section>

        <!-- Process -->
        <section class="border-b border-gray-800 pb-8">
          <h2 class="case-title text-2xl font-semibold relative pb-3 mb-6">
            <span class="text-[#c5a059] mr-2">{esC.sections.process.number}.</span>
            <span data-lang="es">{esC.sections.process.title}</span>
            <span data-lang="en">{enC.sections.process.title}</span>
          </h2>

          <div class="space-y-6">
            {
              esC.sections.process.steps.map((step, i) => (
                <div>
                  <h4 class="text-[#c5a059] font-bold text-base">
                    <span data-lang="es">{step.title}</span>
                    <span data-lang="en">{enC.sections.process.steps[i].title}</span>
                  </h4>
                  <p class="mt-1 text-gray-300 leading-relaxed">
                    <span data-lang="es">{step.body}</span>
                    <span data-lang="en">{enC.sections.process.steps[i].body}</span>
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        <!-- Outcome -->
        <section>
          <h2 class="case-title text-2xl font-semibold relative pb-3 mb-4">
            <span class="text-[#c5a059] mr-2">{esC.sections.outcome.number}.</span>
            <span data-lang="es">{esC.sections.outcome.title}</span>
            <span data-lang="en">{enC.sections.outcome.title}</span>
          </h2>
          <p class="text-gray-300 leading-relaxed">
            <span data-lang="es">{esC.sections.outcome.body}</span>
            <span data-lang="en">{enC.sections.outcome.body}</span>
          </p>
        </section>
      </div>

      <!-- Specs aside -->
      <aside>
        <div class="lg:sticky lg:top-24 rounded-xl border border-[#c5a059]/30 bg-gray-900/50 p-5">
          <h3 class="text-base font-bold border-b border-gray-700 pb-3 mb-4">
            <span data-lang="es">{esC.specs.title}</span>
            <span data-lang="en">{enC.specs.title}</span>
          </h3>

          <div class="space-y-4 text-sm">
            <div>
              <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold">
                <span data-lang="es">{esC.specs.env}</span>
                <span data-lang="en">{enC.specs.env}</span>
              </div>
              <span class="inline-block mt-1 rounded-full bg-stone-100 text-stone-800 border border-stone-300 dark:bg-black dark:text-gray-100 dark:border-gray-700 px-3 py-1 text-xs">
                {esC.specs.envValue}
              </span>
            </div>

            <div>
              <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold">
                <span data-lang="es">{esC.specs.frontend}</span>
                <span data-lang="en">{enC.specs.frontend}</span>
              </div>
              <div class="flex flex-wrap gap-1 mt-1">
                {
                  frontendBadges.map((b) => (
                    <span class="rounded-full border border-stone-300 bg-stone-100 text-stone-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 px-2 py-0.5 text-xs">
                      {b}
                    </span>
                  ))
                }
              </div>
            </div>

            <div>
              <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold">
                <span data-lang="es">{esC.specs.libraries}</span>
                <span data-lang="en">{enC.specs.libraries}</span>
              </div>
              <div class="flex flex-wrap gap-1 mt-1">
                {
                  libraryBadges.map((b) => (
                    <span class="rounded-full border border-stone-300 bg-stone-100 text-stone-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 px-2 py-0.5 text-xs">
                      {b}
                    </span>
                  ))
                }
              </div>
            </div>

            <div>
              <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold">
                <span data-lang="es">{esC.specs.deploy}</span>
                <span data-lang="en">{enC.specs.deploy}</span>
              </div>
              <div class="flex flex-wrap gap-1 mt-1">
                {
                  deployBadges.map((b) => (
                    <span class="rounded-full border border-stone-300 bg-stone-100 text-stone-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 px-2 py-0.5 text-xs">
                      {b}
                    </span>
                  ))
                }
              </div>
            </div>

            <a
              href={esC.specs.ctaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#c5a059] px-4 py-3 text-sm font-bold uppercase tracking-wider text-black transition hover:bg-[#b08d4a]"
            >
              <span data-lang="es">{esC.specs.cta}</span>
              <span data-lang="en">{enC.specs.cta}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <ContactModal />
</BaseLayout>

<style>
  .case-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 50px;
    height: 2px;
    background-color: #c5a059;
  }
</style>
